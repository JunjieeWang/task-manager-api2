# task-manager-api / .env.example
# Copia aquest fitxer a .env i omple els valors reals

# ── MongoDB ────────────────────────────────────────────────────
# URI de connexió a MongoDB Atlas o local
MONGO_JJ=mongodb://localhost:27017/task-manager-t9

# ── JWT ────────────────────────────────────────────────────────
# Secret per signar els Access Tokens (15 min)
JWT_SECRET=canvia_aquest_secret_per_un_de_segur_min32chars

# Secret per signar els Refresh Tokens (7 dies)
# Si no s'especifica, s'utilitza JWT_SECRET
JWT_REFRESH_SECRET=canvia_aquest_refresh_secret_per_un_de_segur

# ── Servidor ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Seed automàtic ────────────────────────────────────────────
# true → executa el seed en arrencar (primera vegada)
# false → no executa el seed
AUTO_SEED=true
