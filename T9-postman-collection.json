  "item": [
    {
      "name": "1. Autenticació",
      "item": [
        {
          "name": "1.1 Registre d'Usuari",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joan@example.com\",\n  \"password\": \"Password123!\",\n  \"firstName\": \"Joan\",\n  \"lastName\": \"Garcia\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test(\"Status 201 Created\", () => pm.response.to.have.status(201));",
            "pm.test(\"Té accessToken\", () => pm.expect(pm.response.json()).to.have.property(\"accessToken\"));",
            "pm.test(\"Té refreshToken\", () => pm.expect(pm.response.json()).to.have.property(\"refreshToken\"));",
            "const body = pm.response.json();",
            "if (body.accessToken) {",
            "  pm.collectionVariables.set(\"accessToken\", body.accessToken);",
            "  pm.collectionVariables.set(\"refreshToken\", body.refreshToken);",
            "  pm.collectionVariables.set(\"userId\", body.user._id);",
            "}"
          ]}}]
        },
        {
          "name": "1.2 Login Correcte",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joan@example.com\",\n  \"password\": \"Password123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test(\"Status 200 OK\", () => pm.response.to.have.status(200));",
            "pm.test(\"Té accessToken\", () => pm.expect(pm.response.json()).to.have.property(\"accessToken\"));",
            "pm.test(\"Té refreshToken\", () => pm.expect(pm.response.json()).to.have.property(\"refreshToken\"));",
            "pm.test(\"expiresIn és 900\", () => pm.expect(pm.response.json().expiresIn).to.eql(900));",
            "const body = pm.response.json();",
            "if (body.accessToken) {",
            "  pm.collectionVariables.set(\"accessToken\", body.accessToken);",
            "  pm.collectionVariables.set(\"refreshToken\", body.refreshToken);",
            "  pm.collectionVariables.set(\"userId\", body.user._id);",
            "}"
          ]}}]
        },
        {
          "name": "1.3 Login amb Password Incorrecte",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joan@example.com\",\n  \"password\": \"PasswordIncorrecte123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test(\"Status 401 Unauthorized\", () => pm.response.to.have.status(401));"
          ]}}]
        },
        {
          "name": "1.4 Renovar Access Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api","auth","refresh"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test(\"Status 200 OK\", () => pm.response.to.have.status(200));",
            "pm.test(\"Té nou accessToken\", () => pm.expect(pm.response.json()).to.have.property(\"accessToken\"));",
            "const body = pm.response.json();",
            "if (body.accessToken) pm.collectionVariables.set(\"accessToken\", body.accessToken);"
          ]}}]
        },
        {
          "name": "1.5 Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","auth","logout"] }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test(\"Status 200 OK\", () => pm.response.to.have.status(200));",
            "// Tornem a fer login per continuar les proves",
            "// Executar 1.2 Login Correcte manualment abans de continuar"
          ]}}]
        },
        {
          "name": "1.6 Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
